{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "outDir": "./dist/",
        "paths": {
            "@/*": ["src/*"]
        },
        "types": ["vite/client"],
        "resolveJsonModule": true,
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "src/**/*.json", "src/vite-env.d.ts"]
}
